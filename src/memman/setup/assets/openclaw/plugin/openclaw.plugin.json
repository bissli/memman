{
  "id": "memman",
  "name": "memman",
  "version": "0.1.0",
  "description": "LLM-supervised persistent memory — recall before responding, remember after",
  "hooks": [
    "before_prompt_build"
  ],
  "entry": "index.js",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "nudge": {
        "type": "boolean"
      },
      "remind": {
        "type": "boolean"
      }
    }
  }
}
