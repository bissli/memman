        <mxCell id="arrow_host_remember" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=2;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="l1" target="h1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow_host_remember_label" value="&lt;font style=&quot;font-size:9px&quot;&gt;memman remember&lt;/font&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;" vertex="1" connectable="0" parent="arrow_host_remember">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <mxCell id="arrow_host_recall" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=2;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="l4" target="h5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow_host_recall_label" value="&lt;font style=&quot;font-size:9px&quot;&gt;memman recall&lt;/font&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;" vertex="1" connectable="0" parent="arrow_host_recall">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <mxCell id="cmp_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="660" width="1240" height="75" as="geometry" />
        </mxCell>
        <mxCell id="cmp" value="&lt;b&gt;vs Embedded LLM (Mem0/MemCP)&lt;/b&gt;: gpt-4o-mini for every operation &amp;rarr; higher API cost, weaker reasoning, single-tier judgment&lt;br&gt;&lt;b&gt;Three-Tier (MemMan)&lt;/b&gt;: Haiku for fast recall expansion, Sonnet split across canonical (extract+reconcile) and metadata (enrich+causal) so each can be tuned, Host LLM for high-value triage &amp;rarr; stronger judgment where it matters, cost-proportional to complexity" style="text;html=1;align=center;fontSize=10;fillColor=none;strokeColor=none;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="50" y="668" width="1200" height="60" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
