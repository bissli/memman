<mxfile host="app.diagrams.net" agent="Claude" version="24.0.0" type="device">
  <diagram id="llm-supervised" name="LLM-Supervised Architecture">
    <mxGraphModel dx="1522" dy="950" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="&lt;b&gt;LLM-Supervised Architecture&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Binary handles deterministic computation; pipeline LLMs (Haiku fast + Sonnet canonical/metadata) handle judgment; Host LLM supervises triage &amp;amp; context&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="150" y="10" width="1100" height="45" as="geometry" />
        </mxCell>

        <mxCell id="bin_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="30" y="75" width="380" height="560" as="geometry" />
        </mxCell>
        <mxCell id="bin_title" value="&lt;b&gt;Binary (Deterministic)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;High-frequency, zero cost, no network&lt;/font&gt;" style="text;html=1;align=center;fontSize=14;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="55" y="85" width="330" height="40" as="geometry" />
        </mxCell>
        <mxCell id="b1" value="&lt;b&gt;Storage&lt;/b&gt;&lt;br&gt;SQLite WAL, ACID, single file" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="140" width="330" height="38" as="geometry" />
        </mxCell>
        <mxCell id="b2" value="&lt;b&gt;Graph Indexing&lt;/b&gt;&lt;br&gt;temporal backbone, entity co-occurrence, auto-edges" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="190" width="330" height="38" as="geometry" />
        </mxCell>
        <mxCell id="b3" value="&lt;b&gt;Keyword Search&lt;/b&gt;&lt;br&gt;tokenization, stopwords, CJK bigrams, scoring" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="240" width="330" height="38" as="geometry" />
        </mxCell>
        <mxCell id="b4" value="&lt;b&gt;RRF Anchor Selection&lt;/b&gt;&lt;br&gt;keyword + vector + recency fusion (K=60)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="290" width="330" height="38" as="geometry" />
        </mxCell>
        <mxCell id="b5" value="&lt;b&gt;Beam Search Traversal&lt;/b&gt;&lt;br&gt;intent-weighted graph exploration, multi-signal reranking" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="340" width="330" height="38" as="geometry" />
        </mxCell>
        <mxCell id="b6" value="&lt;b&gt;Vector Computation&lt;/b&gt;&lt;br&gt;cosine similarity, embedding serialization" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="390" width="330" height="38" as="geometry" />
        </mxCell>
        <mxCell id="b7" value="&lt;b&gt;4-Signal Reranking&lt;/b&gt;&lt;br&gt;keyword + entity + similarity + graph, intent-weighted" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="440" width="330" height="38" as="geometry" />
        </mxCell>
        <mxCell id="b8" value="&lt;b&gt;Lifecycle &amp;amp; Decay&lt;/b&gt;&lt;br&gt;EI formula, auto-prune, immunity rules, GC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="490" width="330" height="38" as="geometry" />
        </mxCell>
        <mxCell id="b9" value="&lt;b&gt;Duplicate Detection&lt;/b&gt;&lt;br&gt;content similarity, negation patterns" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="540" width="330" height="38" as="geometry" />
        </mxCell>

        <mxCell id="haiku_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="460" y="75" width="380" height="560" as="geometry" />
        </mxCell>
        <mxCell id="haiku_title" value="&lt;b&gt;Internal Pipeline LLMs (3 roles)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;fast (Haiku) + slow_canonical (Sonnet) + slow_metadata (Sonnet, tunable); ~4 calls/write + 1 call/recall&lt;/font&gt;" style="text;html=1;align=center;fontSize=14;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="485" y="85" width="330" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h1" value="&lt;b&gt;Fact Extraction&lt;/b&gt; &lt;font style=&quot;font-size:9px&quot;&gt;[slow_canonical]&lt;/font&gt;&lt;br&gt;Decompose input into 1-5 atomic facts with&lt;br&gt;category, importance, entities" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="485" y="145" width="330" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h2" value="&lt;b&gt;Reconciliation&lt;/b&gt; &lt;font style=&quot;font-size:9px&quot;&gt;[slow_canonical]&lt;/font&gt;&lt;br&gt;Compare new fact vs similar existing insights&lt;br&gt;Decide: ADD / UPDATE / DELETE / NONE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="485" y="215" width="330" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h3" value="&lt;b&gt;Enrichment&lt;/b&gt; &lt;font style=&quot;font-size:9px&quot;&gt;[slow_metadata]&lt;/font&gt;&lt;br&gt;Generate keywords, summary, entities for insight&lt;br&gt;(parallel with causal inference)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="485" y="285" width="330" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h4" value="&lt;b&gt;Causal Inference&lt;/b&gt; &lt;font style=&quot;font-size:9px&quot;&gt;[slow_metadata]&lt;/font&gt;&lt;br&gt;Evaluate causal relationships between insights&lt;br&gt;causes / enables / prevents (parallel with enrichment)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="485" y="355" width="330" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h5" value="&lt;b&gt;Query Expansion&lt;/b&gt; &lt;font style=&quot;font-size:9px&quot;&gt;[fast]&lt;/font&gt;&lt;br&gt;Expand recall query with synonyms, entities, intent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="485" y="425" width="330" height="45" as="geometry" />
        </mxCell>

        <mxCell id="haiku_note" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Models:&lt;/b&gt; MEMMAN_LLM_MODEL_FAST (Haiku) + MEMMAN_LLM_MODEL_SLOW_CANONICAL (Sonnet) + MEMMAN_LLM_MODEL_SLOW_METADATA (Sonnet) via OpenRouter; resolved at install, persisted in ~/.memman/env&lt;br&gt;&lt;b&gt;Embeddings:&lt;/b&gt; Voyage voyage-3-lite 512d (default; pluggable: openai / openrouter / ollama)&lt;br&gt;&lt;b&gt;Requires:&lt;/b&gt; OPENROUTER_API_KEY + VOYAGE_API_KEY&lt;/font&gt;" style="text;html=1;align=center;fontSize=10;fillColor=none;strokeColor=none;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="500" y="510" width="300" height="50" as="geometry" />
        </mxCell>

        <mxCell id="host_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="890" y="75" width="380" height="560" as="geometry" />
        </mxCell>
        <mxCell id="host_title" value="&lt;b&gt;Host LLM (Supervisor)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Full conversation context, Opus/Sonnet-level reasoning&lt;/font&gt;" style="text;html=1;align=center;fontSize=14;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="915" y="85" width="330" height="40" as="geometry" />
        </mxCell>
        <mxCell id="l1" value="&lt;b&gt;Memory Triage&lt;/b&gt;&lt;br&gt;Decide what to remember: preferences, decisions,&lt;br&gt;corrections, conclusions, context" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="915" y="150" width="330" height="55" as="geometry" />
        </mxCell>
        <mxCell id="l2" value="&lt;b&gt;Content Composition&lt;/b&gt;&lt;br&gt;Author memory text with appropriate detail,&lt;br&gt;assign category and importance hints" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="915" y="225" width="330" height="55" as="geometry" />
        </mxCell>
        <mxCell id="l3" value="&lt;b&gt;Recall Interpretation&lt;/b&gt;&lt;br&gt;Synthesize recalled memories with conversation context,&lt;br&gt;judge relevance and freshness" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="915" y="300" width="330" height="55" as="geometry" />
        </mxCell>
        <mxCell id="l4" value="&lt;b&gt;Query Formulation&lt;/b&gt;&lt;br&gt;Craft focused, keyword-rich recall queries&lt;br&gt;from conversation context" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="915" y="375" width="330" height="55" as="geometry" />
        </mxCell>
        <mxCell id="l5" value="&lt;b&gt;Lifecycle Oversight&lt;/b&gt;&lt;br&gt;Decide when to update, forget, or link memories&lt;br&gt;based on conversation signals" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="915" y="450" width="330" height="55" as="geometry" />
        </mxCell>

        <mxCell id="host_note" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;No extra API cost&lt;/b&gt; (uses host conversation turns)&lt;br&gt;&lt;b&gt;Full context&lt;/b&gt; (conversation history + tool results)&lt;br&gt;&lt;b&gt;Strongest reasoning&lt;/b&gt; for high-value judgment calls&lt;/font&gt;" style="text;html=1;align=center;fontSize=10;fillColor=none;strokeColor=none;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="930" y="530" width="300" height="50" as="geometry" />
        </mxCell>

        <mxCell id="arrow_write" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="b1" target="h1">
          <mxGeometry relative="1" as="geometry" />
