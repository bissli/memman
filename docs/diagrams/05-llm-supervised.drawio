        <mxCell id="arrow_write_label" value="&lt;font style=&quot;font-size:9px&quot;&gt;write path&lt;/font&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;" vertex="1" connectable="0" parent="arrow_write">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
