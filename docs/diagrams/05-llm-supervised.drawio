        <mxCell id="arrow_recall" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="b5" target="h5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow_recall_label" value="&lt;font style=&quot;font-size:9px&quot;&gt;recall path&lt;/font&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;" vertex="1" connectable="0" parent="arrow_recall">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
