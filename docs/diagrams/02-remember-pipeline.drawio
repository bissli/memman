<mxfile host="app.diagrams.net" agent="Claude" version="24.0.0" type="device">
  <diagram id="remember" name="Remember Pipeline">
    <mxGraphModel dx="1422" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="r_title" value="&lt;b&gt;memman remember Pipeline (deferred, two-tier)&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="280" y="10" width="500" height="30" as="geometry" />
        </mxCell>

        <mxCell id="t1_box" value="&lt;b&gt;Tier 1 — Synchronous queue-append (host session, ~50 ms)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="1020" height="240" as="geometry" />
        </mxCell>

        <mxCell id="r_start" value="memman remember &amp;lt;content&amp;gt;&lt;br&gt;[--cat --imp --tags --entities --source]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="280" height="50" as="geometry" />
        </mxCell>

        <mxCell id="r_validate" value="Validate args&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;importance ∈ [1,5]&lt;br&gt;content ≤ 8000 chars&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="100" width="180" height="50" as="geometry" />
        </mxCell>

        <mxCell id="r_check_state" value="Check scheduler state&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;reject when STOPPED&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="90" width="170" height="70" as="geometry" />
        </mxCell>

        <mxCell id="r_reject" value="Scheduler is stopped;&lt;br&gt;cannot remember." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="830" y="100" width="200" height="50" as="geometry" />
        </mxCell>

        <mxCell id="r_enqueue" value="Append row to ~/.memman/queue.db (SQLite WAL)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;status='pending', priority, queued_at,&lt;br&gt;hint_cat / hint_imp / hint_entities / hint_no_reconcile&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="120" y="180" width="500" height="60" as="geometry" />
        </mxCell>

        <mxCell id="r_return" value="Return JSON&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;{action: queued, queue_id: N, store, quality_warnings}&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="660" y="190" width="370" height="50" as="geometry" />
        </mxCell>

        <mxCell id="r_t1_note" value="&lt;font style=&quot;font-size:9px;color:#9673a6&quot;&gt;No LLM. No embedding. No similarity scan. No edges. The host session never blocks on the network.&lt;/font&gt;" style="text;html=1;align=left;fontSize=9;fillColor=none;strokeColor=none;fontColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="80" y="260" width="900" height="30" as="geometry" />
        </mxCell>

        <mxCell id="r_e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="r_start" target="r_validate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="r_validate" target="r_check_state">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e3" value="STOPPED" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=9;strokeColor=#b85450;" edge="1" parent="1" source="r_check_state" target="r_reject">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e4" value="STARTED" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=9;" edge="1" parent="1" source="r_check_state" target="r_enqueue">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="r_enqueue" target="r_return">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="r_trigger" value="&lt;b&gt;Trigger&lt;/b&gt;  systemd timer (Linux)  ·  launchd agent (macOS)  ·  serve loop PID 1 (container)" style="text;html=1;align=center;fontSize=12;fillColor=none;strokeColor=none;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="1020" height="20" as="geometry" />
        </mxCell>
        <mxCell id="r_trigger_arrow" value="every 60 s (or continuous if --interval 0)" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=9;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="550" y="345" as="sourcePoint" />
            <mxPoint x="550" y="380" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="t2_box" value="&lt;b&gt;Tier 2 — Background worker (memman scheduler drain --pending)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce5cd;strokeColor=#d6b656;verticalAlign=top;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="385" width="1020" height="690" as="geometry" />
        </mxCell>

        <mxCell id="r_lock" value="acquire flock on ~/.memman/drain.lock&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;drains never overlap; concurrent triggers exit 0 with 'another drain in progress'&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="420" width="500" height="50" as="geometry" />
        </mxCell>

        <mxCell id="r_claim" value="Atomic claim&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;UPDATE queue SET claimed_at=..., attempts=attempts+1&lt;br&gt;WHERE id = (SELECT ... WHERE status='pending'&lt;br&gt;ORDER BY priority DESC, queued_at ASC LIMIT 1) RETURNING ...&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fce5cd;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="490" width="500" height="70" as="geometry" />
        </mxCell>

        <mxCell id="r_idem" value="Idempotency check&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;if any insight has source='queue:&amp;lt;id&amp;gt;'&lt;br&gt;→ skip + mark done (crash recovery)&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="495" width="220" height="80" as="geometry" />
        </mxCell>

        <mxCell id="r_qg" value="Quality gate&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;check_content_quality(content)&lt;br&gt;reject ≥ 2 transient warnings&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="590" width="280" height="55" as="geometry" />
        </mxCell>

        <mxCell id="r_extract" value="LLM fact extraction&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;extract_facts() → 1-5 atomic facts&lt;br&gt;each with category, importance, entities&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="665" width="280" height="55" as="geometry" />
        </mxCell>

        <mxCell id="r_perfact" value="&lt;b&gt;Per-fact&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="740" width="940" height="160" as="geometry" />
        </mxCell>

        <mxCell id="r_embed" value="Embed (Voyage 512d default;&lt;br&gt;openai_compat / ollama optional)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;serialize_vector → BLOB&lt;br&gt;dim × 8 bytes&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="775" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="r_sim" value="Find similar&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;keyword search (top 5)&lt;br&gt;+ cosine scan (≥ 0.5)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="320" y="775" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="r_recon" value="LLM reconcile&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;ADD / UPDATE / DELETE / NONE&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="775" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="r_apply" value="Apply action&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;INSERT new / UPDATE existing /&lt;br&gt;soft-DELETE / SKIP&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="775" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="r_e_pf1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="r_embed" target="r_sim">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_pf2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="r_sim" target="r_recon">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_pf3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="r_recon" target="r_apply">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="r_fast" value="&lt;b&gt;Fast edges&lt;/b&gt; (per fact)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;temporal (backbone + 4h proximity, MAX_PROXIMITY_EDGES=5) ·&lt;br&gt;entity (IDF-weighted, MAX_ENTITY_LINKS=5/entity, MAX_TOTAL_ENTITY_EDGES=50) ·&lt;br&gt;semantic (cos ≥ AUTO_SEMANTIC_THRESHOLD=0.62, MAX_AUTO_SEMANTIC_EDGES=3)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="920" width="940" height="65" as="geometry" />
        </mxCell>

        <mxCell id="r_parallel" value="&lt;b&gt;Parallel enrichment&lt;/b&gt; (ThreadPoolExecutor, 2 workers)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;A: enrich_with_llm() — keywords, summary, semantic_facts, refined entities&amp;nbsp;&amp;nbsp;|&amp;nbsp;&amp;nbsp;B: infer_llm_causal_edges() — causes/enables/prevents (LLM_CONFIDENCE_FLOOR=0.75)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE6E6;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="1000" width="940" height="55" as="geometry" />
        </mxCell>

        <mxCell id="r_done" value="Re-embed with enriched keywords  ·  rebuild auto edges  ·  refresh effective importance  ·  auto_prune  ·  mark_done(queue_id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="1090" width="1020" height="40" as="geometry" />
        </mxCell>

        <mxCell id="r_e_lock_claim" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="r_lock" target="r_claim">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_claim_idem" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="r_claim" target="r_idem">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_idem_qg" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="r_idem" target="r_qg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_qg_ext" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="r_qg" target="r_extract">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_ext_pf" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="r_extract" target="r_perfact">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_pf_fast" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="r_perfact" target="r_fast">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_fast_par" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="r_fast" target="r_parallel">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_par_done" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" parent="1" source="r_parallel" target="r_done">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
